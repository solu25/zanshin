# ============================================================
# ZANSHIN — env var template
# Copy this file to .env.local and fill in real values.
# .env.example is committed; .env.local is gitignored.
# ============================================================

# Supabase project URL (Project Settings → API → Project URL)
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon public key (Project Settings → API → Project API keys → anon public)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service_role key (Project Settings → API → service_role).
# Server-only. Never NEXT_PUBLIC_ this.
SUPABASE_SERVICE_ROLE_KEY=
